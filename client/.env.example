# Baked in at `npm run build`. Set in the Vercel project (Production + Preview) to
# your Railway public API URL, e.g. https://brantsimpson-api.up.railway.app
VITE_API_BASE_URL=https://your-api.up.railway.app

# Cloudflare Turnstile site key (public — safe to expose in client JS).
# Get it from: Cloudflare Dashboard → Turnstile → <your site> → Site Key
# When left empty in dev, the form bypasses Turnstile automatically.
VITE_TURNSTILE_SITE_KEY=
