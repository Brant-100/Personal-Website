# Required — Resend transactional email
# Sign up at https://resend.com, verify brantsimpson.com domain, generate API key.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where Brant's inquiry notification goes
CONTACT_TO_EMAIL=brant@brantsimpson.com

# The From address (must be on a Resend-verified domain)
CONTACT_FROM_EMAIL=contact@brantsimpson.com

# Required — Cloudflare Turnstile secret key (keep secret, never commit)
# Get from: Cloudflare Dashboard → Turnstile → <site> → Secret Key
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxxx

# Dev / test only — set to 1 to bypass Turnstile verification
# TURNSTILE_BYPASS=1

# Extra CORS origins (comma-separated), appended to the built-in list
# CORS_EXTRA_ORIGINS=https://my-preview.vercel.app
